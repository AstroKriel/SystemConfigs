#!/bin/sh
# Dynamically finds the amdgpu hwmon directory, then finds the edge label
# and reads its corresponding temp input. Nothing is hardcoded.
dir=$(grep -rl '^amdgpu$' /sys/class/hwmon/hwmon*/name 2>/dev/null | head -1 | xargs -r dirname)
input=$(grep -rl '^edge$' "$dir"/temp*_label 2>/dev/null | head -1 | sed 's/_label$/_input/')
awk '{printf "%d C", $1/1000}' "$input"
