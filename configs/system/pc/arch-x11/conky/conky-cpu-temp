#!/bin/sh
# Dynamically finds the k10temp hwmon directory, then finds the Tctl label
# and reads its corresponding temp input. Nothing is hardcoded.
dir=$(grep -rl '^k10temp$' /sys/class/hwmon/hwmon*/name 2>/dev/null | head -1 | xargs -r dirname)
input=$(grep -rl '^Tctl$' "$dir"/temp*_label 2>/dev/null | head -1 | sed 's/_label$/_input/')
awk '{printf "%d C", $1/1000}' "$input"
