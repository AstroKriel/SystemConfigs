##
## === FZF FILE OPENING
##

if command -v fzf >/dev/null 2>&1; then
    fzfs() {
        local dir="${1:-.}"
        local preview="cat {}"
        if command -v bat >/dev/null 2>&1; then
            preview="bat --style=numbers --color=always {}"
        fi
        find "$dir" -type f 2>/dev/null | fzf --preview="$preview"
    }

    if command -v nvim >/dev/null 2>&1; then
        fzfn() { local file=$(fzfs "$1"); [[ -n $file ]] && nvim "$file"; }
    fi

    if command -v code >/dev/null 2>&1; then
        fzfc() { local file=$(fzfs "$1"); [[ -n $file ]] && code "$file"; }
    fi
fi

##
## === TMUX WORKFLOWS
##

## launch a live latex compile + pdf preview session, anchored to the project
## dir (where the tex file lives) regardless of where invoked.
if command -v tmux >/dev/null 2>&1; then
    tmux-cv-latex() {
        for cmd in latexmk zathura realpath; do
            command -v "$cmd" >/dev/null 2>&1 \
                || { echo "tmux-cv-latex: $cmd not found" >&2; return 1; }
        done
        local tex_path="${1:?usage: tmux-cv-latex <file.tex>}"
        local tex_abs tex_dir tex_file pdf_file session
        tex_abs="$(realpath "$tex_path")"  ## requires the dir to exist; catches bad paths early
        tex_dir="$(dirname "$tex_abs")"
        tex_file="$(basename "$tex_abs")"
        pdf_file="${tex_file%.tex}.pdf"
        ## name from project dir so calls from different cwds reuse the session
        session="latex-$(basename "$tex_dir")"
        if tmux has-session -t "$session" 2>/dev/null; then
            tmux attach-session -t "$session"
            return
        fi
        ## anchor both panes in `tex_dir` so build outputs land next to the source
        tmux new-session -d -s "$session" -c "$tex_dir"
        ## `-g` forces an initial recompile to produce `.synctex.gz`
        tmux send-keys -t "$session" "latexmk -pdf -pvc -synctex=1 -g $tex_file" C-m
        tmux split-window -v -t "$session" -c "$tex_dir"
        ## poll for the pdf to avoid racing latexmk's first compile
        tmux send-keys -t "$session" \
            "while [ ! -f $pdf_file ]; do sleep 0.2; done && zathura $pdf_file" C-m
        ## `session:window.pane` is required tmux target syntax; `.0` alone is invalid
        tmux select-pane -t "${session}:0.0"
        tmux attach-session -t "$session"
    }
fi

